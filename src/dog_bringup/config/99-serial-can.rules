#更新配置
#sudo udevadm control --reload-rules
#sudo udevadm trigger

#IMU 串口
SUBSYSTEM=="tty", ATTRS{idVendor}=="19f5", ATTRS{idProduct}=="5740", SYMLINK+="ttyimu"

# 前左腿总线
SUBSYSTEM=="net", ACTION=="add", KERNELS=="3-1.2", NAME="can0"
# 前右腿总线
SUBSYSTEM=="net", ACTION=="add", KERNELS=="3-1.3", NAME="can1"
# 后左腿总线
SUBSYSTEM=="net", ACTION=="add", KERNELS=="3-1.1", NAME="can2"
# 后右腿总线
SUBSYSTEM=="net", ACTION=="add", KERNELS=="3-1.4", NAME="can3"

